# ─── Synup Next.js — Environment Variables ─────────────────────────────────
#
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Site URL ────────────────────────────────────────────────────────────────
# Full URL of the deployed site (no trailing slash).
# Used for: canonical tags, sitemap, og:image absolute URLs, robots.txt
# Production:  https://www.synup.com
# Staging:     https://staging.synup.com (or your preview URL)
NEXT_PUBLIC_SITE_URL=https://www.synup.com

# ─── Contact Form API ────────────────────────────────────────────────────────
# Endpoint that /api/contact POSTs to (e.g. HubSpot, Salesforce, internal CRM).
# If using a third-party webhook, paste the full URL here.
# Example: https://api.hubapi.com/submissions/v3/integration/submit/...
CONTACT_FORM_ENDPOINT=

# HubSpot portal ID and form GUID (if using HubSpot form submissions API)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# ─── Analytics ───────────────────────────────────────────────────────────────
# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Only needed if NOT using GTM
NEXT_PUBLIC_GA4_ID=

# ─── Phase 2: Tolgee (Translation Management) ────────────────────────────────
# Used post-launch for Tolgee MCP integration and auto-translation workflow.
# Leave blank for Phase 1 (static JSON content).
TOLGEE_API_URL=https://app.tolgee.io
TOLGEE_API_KEY=

# ─── Phase 2: DeepL (Auto-Translation) ───────────────────────────────────────
# Used by the GitHub Action auto-translation pipeline post-launch.
DEEPL_API_KEY=

# ─── Image CDN ───────────────────────────────────────────────────────────────
# Webflow asset CDN base URL (used in next.config.ts remotePatterns)
# Only change if assets are migrated to a different CDN
NEXT_PUBLIC_ASSET_CDN=https://cdn.prod.website-files.com

# ─── Deployment ──────────────────────────────────────────────────────────────
# Set by CI/CD — do not set manually in .env.local
# NODE_ENV=production
# VERCEL_URL=
# PORT=3000
